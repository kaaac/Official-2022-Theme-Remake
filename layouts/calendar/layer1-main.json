{
    "BlockRoot": {
        "Name": "mainStack",
        "BlockType": "stack",
        "Margin": "{MarginRoot}",
        "Orientation": "Vertical",
        "Items": [
            {
                "BlockType" : "component",
                "Component" : "header_block",
                "ComponentOptions" : {
                    "Vars" : {
                        "headerlefttext" : "{Season.LeagueInfo.LeagueShortName} · {Season.Name} · [Calendar]"
                    }
                }
            },
            {
                "BlockType" : "component",
                "Component" : "separator"
            },
            {
                "Name": "mainTable",
                "BlockType": "table",
                "Margin": "{MarginTable}",
                "MarginRight": 0,
                "TableOptions": {
                    "ItemsSource": "{Events.Events}",
                    "RowSpacing": 0,
                    "ColSpacing": 0,
                    "HeaderTemplate": {
                        "BlockType": "text",
                        "MarginBottom": 8
                    },
                    "Columns": [
                        {
                            "Template": {
                                "BlockType": "text",
                                "PaddingLeft": 48,
                                "Source": "{Item.Position}",
                                "HorizontalAlignment": "Center",
                                "VerticalAlignment": "Center",
                                "Style" : "positionNumber",
                                "TextOptions": {
                                    "HorizontalAlignment": "Center"
                                }
                            }
                        },

                        {
                            "Template": {
                                "BlockType": "stack",
                                "PaddingLeft": 32,
                                "PaddingRight": 4,
                                "HorizontalAlignment": "Left",
                                "VerticalAlignment": "Center",
                                "Items": [
                                    {
                                        "BlockType": "image",
                                        "Height": 56,
                                        "PaddingTop": 0,
                                        "PaddingBottom": 0,
                                        "MarginRight": 20,
                                        "VerticalAlignment": "Center",
                                        "ImageOptions": {
                                            "Path": "{Item.Track.Nation.LogotypePath}",
                                            "VerticalAlignment": "Center"
                                        }
                                    },
                                    {
                                        "BlockType": "text",
                                        "Source": "{Item.Track.Nation.Code}",
                                        "HorizontalAlignment": "Left",
                                        "VerticalAlignment": "Center",
                                        "Style" : "calendarText"
                                    }
                                ]
                            }
                        },
                        {
                            "WidthStretch": true,
                            "Template": {
                                "BlockType": "text",
                                "PaddingLeft": 24,
                                "PaddingRight": 56,
                                "Source": "{Item.Track.CircuitName}",
                                "HorizontalAlignment": "Left",
                                "VerticalAlignment": "Center",
                                "Style" : "calendarText"
                            }
                        },
                        {
                            "Template": {
                                "BlockType": "text",
                                "PaddingLeft": 48,
                                "PaddingRight": 48,
                                "Source": "{Item.Date, Converter=DateToDayOfMonth}.{Item.Date, Converter=DateToMonth}",
                                "Style" : "calendarText",
                                "TextOptions": {
                                    "HorizontalAlignment": "Center"
                                }
                            }
                        },
                        {
                            "Template": {
                                "BlockType": "text",
                                "RenderIf": "{ShowWinnerInCalendar}",
                                "MaxWidth": 320,
                                "PaddingLeft": 48,
                                "PaddingRight": 48,
                                "Source": "{Item.WinnerString}",
                                "HorizontalAlignment": "Left",
                                "VerticalAlignment": "Center",
                                "Style" : "calendarWinner"
                            }
                        }
                    ]
                }
            },
            {
                "BlockType" : "component",
                "Component" : "bg_footer"
            }
        ]
    }
}
