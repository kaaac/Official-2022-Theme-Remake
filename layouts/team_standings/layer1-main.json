{
    "BlockRoot": {
        "Name": "mainStack",
        "BlockType": "stack",
        "Margin": "{MarginRoot}",       
        "Orientation": "Vertical",
        "Items": [
            {
                "BlockType" : "component",
                "ComponentName" : "header_block",
                "ComponentOptions" : {
                    "Vars" : {
                        "headerlefttext" : "{Season.LeagueInfo.LeagueName} · {Season.Name} · Team Standings"
                    }
                }
            },
            {
                "BlockType" : "component",
                "ComponentName" : "separator"
            },
            {
                "Name": "mainTable",
                "BlockType": "table",
                "Margin" : "{MarginTable}",
                "MarginRight" : 200,
                "TableOptions": {
                    "ItemsSource": "{Standings.Teams}",
                    "HeaderTemplate": {
                        "BlockType": "text",
                        "Style" : "tableHeader"
                    },
                    "Columns": [
                        {
                            "Header": "",
                            "Template": {
                                "BlockType" : "component",                                
                                "ComponentName" : "position_cell",
                                "ComponentOptions" :{
                                    "Vars" :{
                                        "position" : "{Item.Position}"
                                    }
                                }                           
                            }
                        },
                        {
                            "Header": "",
                            "WidthStretch" : true,                            
                            "Template": {
                                "BlockType" : "component",
                                "ComponentName" : "team_cell",
                                "ComponentOptions" :{
                                    "Vars" :{
                                        "MarginRight" : "",
                                        "RenderIf" : "{RenderTeamBadgesOnOtherLayouts}"
                                    }
                                }
                            }
                        },
                        {
                            "Header": "[PTS]",
                            "MarginLeft" : 20,
                            "Template": {
                                
                                "BlockType": "dock",
                                "PaddingLeft" : 24,
                                "PaddingRight" : 24,                                
                                "Items": [                                    
                                    {
                                        "BlockType": "text",
                                        "Source": "{Item.Points}",
                                        "HorizontalAlignment": "Right",
                                        "VerticalAlignment": "Center",
                                        "Style": "positionNumber"
                                    }
                                ],
                                "Triggers" :
                                [
                                    {
                                        "Condition" : "{Standings.IsPositionJumpForTeamsExists}",
                                        "Property" : "PaddingRight",
                                        "Value" : 4
                                    }
                                ]
                            }
                        },
                        {
                            "Header": "",
                            "PaddingLeft" : 0,
                            "MarginLeft" : -4,
                            "Template":
                            {
                                "BlockType" : "component",
                                "PaddingLeft" : 0,                               
                                "PaddingRight" : 12,
                                "ComponentName" : "jump_cell"    
                            }
                        },
                        {
                            "Header" : "[Wins]",
                            "MarginLeft" : 20,
                            "Template":{
                                "BlockType" : "text",
                                "Padding": "24, 0",
                                "Source" : "{Item.CountP1, Converter=NumberZeroToEmpty}",
                                "Style" : "positionNumber"
                            }
                        },
                        {
                            "Header" : "[2nd]",
                            "MarginLeft" : 0,
                            "Template":{
                                "BlockType" : "text",
                                "Padding": "24, 0",
                                "Source" : "{Item.CountP2, Converter=NumberZeroToEmpty}",
                                "Style" : "positionNumber"
                            }
                        },
                        {
                            "Header" : "[3rd]",
                            "MarginLeft" : 0,
                            "Template":{
                                "BlockType" : "text",
                                "Padding": "24, 0",
                                "Source" : "{Item.CountP3, Converter=NumberZeroToEmpty}",
                                "Style" : "positionNumber"
                            }
                        },
                        {
                            "Header" : "[FL]",
                            "MarginLeft" : 12,
                            "Template":{
                                "BlockType" : "text",
                                "Padding": "24, 0",
                                "Source" : "{Item.RaceFastestLapCount, Converter=NumberZeroToEmpty}",
                                "Style" : "positionNumber"
                            }
                        },
                        {
                            "Header" : "[Poles]",
                            "MarginLeft" : 0,
                            "Template":{
                                "BlockType" : "text",
                                "Padding": "24, 0",
                                "Source" : "{Item.CountQualP1, Converter=NumberZeroToEmpty}",
                                "Style" : "positionNumber"
                            }
                        },
                        {
                            "Header" : "[Events]",
                            "MarginLeft" : 12,
                            "Template":{
                                "BlockType" : "text",
                                "Padding": "24, 0",
                                "Source" : "{Item.EventsCount, Converter=NumberZeroToEmpty}",                                
                                "Style" : "positionNumber",
                                "MarginRight":30
                            }
                        }


                    ]
                }
            },
            {
                "BlockType" : "component",
                "ComponentName" : "bg_footer"
            }
        ]
    }
}